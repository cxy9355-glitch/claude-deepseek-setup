# ── 飞书配置（必填）──────────────────────────────────────
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 允许收发消息的飞书 chat_id（群 ID 或单聊 ID，oc_ 开头）
FEISHU_CHAT_ID=oc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── DeepSeek 配置（必填）─────────────────────────────────
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Claude 执行配置──────────────────────────────────────
# claude 的工作目录（--add-dir 和 cwd），留空则使用 bridge.py 所在目录
WORKSPACE=G:\Codex\个人

# 默认模型（对应 ANTHROPIC_MODEL）
CLAUDE_MODEL=deepseek-v4-flash

# 高级模型（对应 ANTHROPIC_DEFAULT_OPUS_MODEL）
CLAUDE_OPUS_MODEL=deepseek-v4-pro

# ── 运行配置────────────────────────────────────────────
# 单次任务超时秒数，默认 1800（30 分钟）
TASK_TIMEOUT=1800
